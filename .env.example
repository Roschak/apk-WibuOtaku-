# ═══════════════════════════════════════════════
# WibuOtaku — Environment Variables
# ═══════════════════════════════════════════════
#
# Cara pakai:
#   1. Copy file ini → .env.local
#   2. Isi nilai sesuai kebutuhan
#   3. Jangan commit .env.local ke git
#
# Prefix NEXT_PUBLIC_ → bisa dibaca dari browser (client components)
# Tanpa prefix        → hanya terbaca di server components / API routes
#
# ═══════════════════════════════════════════════

## ── AniList API ──────────────────────────────────
# AniList GraphQL API bisa diakses publik tanpa key.
# Tapi kalau mau rate limit lebih tinggi, daftar OAuth di:
# https://anilist.co/settings/developer
#
# ⚠️ Client Secret jangan pakai prefix NEXT_PUBLIC_ — itu dikirim ke browser!
# NEXT_PUBLIC_ANILIST_CLIENT_ID=
# ANILIST_CLIENT_SECRET=


## ── Jikan API (MyAnimeList unofficial) ──────────
# Jikan API v4 adalah REST API publik — tanpa key.
# Tidak ada env var yang diperlukan.


## ── Keystore (Signing APK Android) ──────────────
# Untuk build APK release yang signed (bisa update tanpa uninstall).
# Generate keystore: bash scripts/setup-keystore.sh
#
# KEYSTORE_PATH=keystore.jks
# KEYSTORE_PASSWORD=
# KEY_ALIAS=wibuotaku-release-key
# KEY_PASSWORD=


## ── Vercel / Deployment ─────────────────────────
# Tidak ada env var khusus yang diperlukan untuk deploy.
# Cukup import repo ke Vercel, build akan jalan otomatis.
